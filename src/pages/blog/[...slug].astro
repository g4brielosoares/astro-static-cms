---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostContent from "@/components/blog/post/PostContent.astro";
import PostHead from "@/components/seo/PostHead.astro";
import placeholder from "@/assets/post-placeholder.png";
import { getPostData, getPublishedPosts, type Post } from "@/utils/blog";
import { getFirstParagraphFromMarkdown } from "@/utils/markdown";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
const postData = getPostData(post);
const { Content } = await render(post);
const description =
  postData.description ?? getFirstParagraphFromMarkdown(post.body ?? "");
const imageURL =
  typeof postData.cover === "string"
    ? postData.cover
    : postData.cover?.src ?? placeholder.src;
---

<Layout
  title={postData.title}
  {description}
  {imageURL}
  imageAlt={postData.coverAlt}
  canonicalURL={`/blog/${postData.slug}/`}
  openGraphType="article"
>
  <PostHead
    slot="head"
    title={postData.title}
    slug={postData.slug}
    {description}
    {imageURL}
    publishedTime={postData.createdTime}
    modifiedTime={postData.lastEditedTime}
    author={postData.author}
    tags={postData.tags}
  />

  <PostContent
    title={postData.title}
    slug={postData.slug}
    createdTime={postData.createdTime}
    author={postData.author}
    tags={postData.tags}
    lastEditedTime={postData.lastEditedTime}
    cover={postData.cover}
    coverAlt={postData.coverAlt}
  >
    <Content />
  </PostContent>
</Layout>
