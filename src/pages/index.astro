---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/layout/Container.astro";
import HomeData from "@/content/data/home/page.data.json";

interface HomeLink {
  label: string;
  href: string;
}

interface HomeContent {
  hero: {
    eyebrow: string;
    title: string;
    description: string;
    primaryLink: HomeLink;
    secondaryLink: HomeLink;
  };
  features: {
    title: string;
    description: string;
  }[];
}

const { hero, features } = HomeData as HomeContent;
---

<Layout>
  <Container class="py-16 md:py-24">
    <section class="max-w-3xl space-y-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-zinc-500">
        {hero.eyebrow}
      </p>
      <h1>{hero.title}</h1>
      <p class="text-lg text-zinc-600 md:text-xl">
        {hero.description}
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a class="button button-primary" href={hero.primaryLink.href}>
          {hero.primaryLink.label}
        </a>
        <a
          class="button button-secondary"
          href={hero.secondaryLink.href}
          target="_blank"
        >
          {hero.secondaryLink.label}
        </a>
      </div>
    </section>

    <section class="mt-16 grid gap-4 md:grid-cols-3">
      {
        features.map((feature) => (
          <article class="rounded-lg border border-zinc-200 bg-white p-6">
            <h2 class="text-xl">{feature.title}</h2>
            <p class="mt-3 text-zinc-600">{feature.description}</p>
          </article>
        ))
      }
    </section>
  </Container>
</Layout>
