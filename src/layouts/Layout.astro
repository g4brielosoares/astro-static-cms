---
import "@/styles/global.css";

import BaseHead from "@/components/seo/BaseHead.astro";
import type { Props as BaseHeadProps } from "@/components/seo/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import { Font } from "astro:assets";

export interface Props extends BaseHeadProps {}

const headProps = Astro.props as Props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead {...headProps} />
    <slot name="head" />
    <Font cssVariable="--font-atkinson-body" preload />
    <Font cssVariable="--font-jetbrains-mono" />
  </head>
  <body class="min-h-screen bg-zinc-50 text-zinc-950 antialiased">
    <Header />
    <main class="min-h-[calc(100vh-8rem)]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
