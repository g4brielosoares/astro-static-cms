---
import type { Post } from "@/utils/blog";
import PostItem from "@/components/blog/listing/PostItem.astro";

interface Props {
  posts: Post[];
  emptyMessage?: string;
  activeTag?: string;
}

const {
  posts,
  emptyMessage = "Nenhum post encontrado para este filtro.",
  activeTag,
} = Astro.props;
---

{
  posts.length > 0 ? (
    <section class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {posts.map((post) => (
        <PostItem post={post} activeTag={activeTag} />
      ))}
    </section>
  ) : (
    <p class="rounded-lg border border-zinc-200 bg-white p-6 text-zinc-600">
      {emptyMessage}
    </p>
  )
}
